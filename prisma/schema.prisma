// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 8.1 Entité Histoire (Mise à jour)
// ------------------------------------------------------
model Histoire {
  id            String   @id @default(uuid())
  titre         String
  slug          String   @unique
  resume        String?
  description   String?
  image         String?
  statut        String   @default("BROUILLON")
  pointDeDepart String?
  dateCreation  DateTime @default(now())
  dateMiseAJour DateTime @updatedAt

  auteurId String?
  auteur   Admin?  @relation(fields: [auteurId], references: [id], onDelete: SetNull)

  chapitres   Chapitre[]
  objets      Objet[]
  sauvegardes Sauvegarde[]
}

// ------------------------------------------------------
// 8.2 Entité Chapitre (Nœud narratif)
// ------------------------------------------------------
model Chapitre {
  id           String  @id @default(uuid())
  histoireId   String
  titreInterne String?
  contenu      String  @db.Text
  image        String?
  effetsEntree Json?
  ordre        Int?

  histoire      Histoire     @relation(fields: [histoireId], references: [id], onDelete: Cascade)
  choixSortants Choix[]      @relation("ChoixSource")
  choixEntrants Choix[]      @relation("ChoixDestination")
  sauvegardes   Sauvegarde[]
}

// ------------------------------------------------------
// 8.3 Entité Choix (Embranchements)
// ------------------------------------------------------
model Choix {
  id                    String  @id @default(uuid())
  chapitreSourceId      String
  libelle               String
  destinationChapitreId String?
  conditions            Json?
  effets                Json?
  testAssocie           Json?

  // Relations
  chapitreSource      Chapitre  @relation("ChoixSource", fields: [chapitreSourceId], references: [id], onDelete: Cascade)
  chapitreDestination Chapitre? @relation("ChoixDestination", fields: [destinationChapitreId], references: [id], onDelete: SetNull)
}

// ------------------------------------------------------
// 8.4 Entité Objet (Inventaire)
// ------------------------------------------------------
model Objet {
  id          String  @id @default(uuid())
  histoireId  String?
  nom         String
  description String?
  type        String
  effet       Json?

  // Relation
  histoire Histoire? @relation(fields: [histoireId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 8.5 Entité Article (Blog / Actus)
// ------------------------------------------------------
model Article {
  id              String    @id @default(uuid())
  titre           String
  slug            String    @unique
  extrait         String?
  contenu         String    @db.Text
  image           String?
  statut          String    @default("BROUILLON")
  datePublication DateTime?
  dateCreation    DateTime  @default(now())
  dateMiseAJour   DateTime  @updatedAt
}

// ------------------------------------------------------
// 8.6 Entité Admin / Staff (Mise à jour)
// ------------------------------------------------------
model Admin {
  id              String @id @default(uuid())
  login           String @unique
  motDePasseHashe String

  role String @default("AUTEUR")

  dateDerniereConnex DateTime?
  dateCreation       DateTime  @default(now())

  histoires Histoire[]
}

// ------------------------------------------------------
// 8.7 Entité Utilisateur (Joueur)
// ------------------------------------------------------
model Utilisateur {
  id                 String    @id @default(uuid())
  pseudo             String    @unique
  email              String    @unique
  motDePasseHashe    String
  dateCreation       DateTime  @default(now())
  dateDerniereConnex DateTime?

  // Relations
  sauvegardes Sauvegarde[]
}

// ------------------------------------------------------
// 8.8 Entité Sauvegarde (État de la partie)
// ------------------------------------------------------
model Sauvegarde {
  id                String @id @default(uuid())
  utilisateurId     String
  histoireId        String
  chapitreCourantId String

  pointsDeVie      Int   @default(20)
  caracteristiques Json?
  inventaire       Json?
  variablesEtat    Json?

  dateCreation  DateTime @default(now())
  dateMiseAJour DateTime @updatedAt

  utilisateur     Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  histoire        Histoire    @relation(fields: [histoireId], references: [id], onDelete: Cascade)
  chapitreCourant Chapitre    @relation(fields: [chapitreCourantId], references: [id], onDelete: Restrict)

  @@unique([utilisateurId, histoireId])
}
